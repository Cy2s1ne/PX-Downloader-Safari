{
	"manifest_version": 2,
	"name": "PX Downloader",
	"version": "2.1",
	"description": "视频下载插件，支持多种视频网站的视频下载和链接复制。",
	"author": "Zgao",
	"permissions": [
		"downloads",
		"activeTab",
		"clipboardWrite",
		"https://*.pornhub.com/*",
		"https://*.pornhubpremium.com/*",
		"https://www.xvideos.com/*"
	],
	"icons":
	{
		"16": "./img/ph16.png",
		"48": "./img/ph48.png",
		"128": "./img/ph128.png"
	},
	"browser_action":
	{
		"default_icon": "./img/ph16.png",
		"default_popup": "popup.html"
	},
	"content_scripts":
	[
		{
			"matches": [
				"https://*.pornhub.com/view_video.php?viewkey=*",
				"https://*.pornhubpremium.com/view_video.php?viewkey=*",
				"https://www.xvideos.com/*"
			],
			"js": ["content-script.js"]
		}
	],
	"homepage_url": "https://zgao.top"
}
